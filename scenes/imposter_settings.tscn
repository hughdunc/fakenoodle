[node name="AgainExplain" type="Label" parent="VBoxContainer/PanelContainer/MarginContainer/VBoxContainer/ScrollContainer/List" unique_id=2085544320]
layout_mode = 2
theme_override_constants/line_spacing = -4
theme_override_font_sizes/font_size = 12
text = "Not based on how many players you have. Example: 

If at 100%, with 4 players, the last imposter has a 25% chance to be imposter again, and everybody else has 25% too.

If at 50%, with 4 players, the last imposter has a 12.5% chance to be imposter again, and everybody else has a 29.166% chance to be imposter.

This stacks, so if at 50%, with 4 players, and someone was imposter 2 times, their chances for next round would be 6.25% to be imposter."
autowrap_mode = 3

