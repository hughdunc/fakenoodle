[node name="StartExplain" type="Label" parent="VBoxContainer/PanelContainer/MarginContainer/VBoxContainer/ScrollContainer/List" unique_id=1976908030]
layout_mode = 2
theme_override_constants/line_spacing = -4
theme_override_font_sizes/font_size = 12
text = "Not based on how many players you have. Example: 

If at 100%, with 4 players, imposter has a 25% chance to go first, and everybody else has 25% too. 

If at 50%, with 4 players, imposter has a 12.5% chance to go first, and everybody else has a 29.166% chance to go first."
